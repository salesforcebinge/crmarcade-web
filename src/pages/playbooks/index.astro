---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import AppShell from "@components/app/AppShell.astro";
import { Icon } from "astro-icon/components";

const playbooks = await getCollection("playbooks");

// Group by phase in lifecycle order
const phaseOrder = ["Pre-Sales", "Discovery", "Design", "Build", "Stabilize", "Operate", "Cross-Phase"];

const grouped = playbooks.reduce((acc, pb) => {
  const phase = pb.data.phase;
  if (!acc[phase]) acc[phase] = [];
  acc[phase].push(pb);
  return acc;
}, {} as Record<string, typeof playbooks>);

const orderedPhases = phaseOrder.filter(p => grouped[p]);

const audienceColors: Record<string, string> = {
  "All Levels": "bg-gray-50 text-gray-700 ring-gray-600/20 dark:bg-gray-400/10 dark:text-gray-400 dark:ring-gray-400/30",
  "Junior Architect": "bg-green-50 text-green-700 ring-green-600/20 dark:bg-green-400/10 dark:text-green-400 dark:ring-green-400/30",
  "Senior Architect": "bg-amber-50 text-amber-700 ring-amber-600/20 dark:bg-amber-400/10 dark:text-amber-400 dark:ring-amber-400/30",
  "CTA-Track": "bg-red-50 text-red-700 ring-red-600/20 dark:bg-red-400/10 dark:text-red-400 dark:ring-red-400/30",
};
---

<BaseLayout title="Architecture Playbooks" description="How architects actually work. Process, methodology, and the thinking that ships projects.">
  <AppShell>
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
          <span class="text-gray-900 dark:text-white">Architecture </span>
          <span class="text-primary-600 dark:text-primary-400">Playbooks</span>
        </h1>
        <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">
          How architects actually work. Process, methodology, and the thinking that ships projects.
        </p>
      </div>

      {playbooks.length === 0 ? (
        <div class="text-center py-20">
          <Icon name="tabler:route" class="w-12 h-12 text-gray-300 dark:text-gray-600 mx-auto mb-4" />
          <p class="text-gray-500 dark:text-gray-400 text-lg">Playbooks are coming soon.</p>
          <p class="text-gray-400 dark:text-gray-500 text-sm mt-2">Methodology guides for the architect's workflow. Check back shortly.</p>
        </div>
      ) : (
        <div class="space-y-10">
          {orderedPhases.map((phase) => (
            <div>
              <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-4 border-b border-gray-100 dark:border-gray-800 pb-2">
                {phase}
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {grouped[phase].map((pb) => (
                  <a
                    href={`/playbooks/${pb.id}`}
                    class="block rounded-lg border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 hover:border-gray-300 dark:hover:border-gray-600 hover:shadow-sm transition-all duration-200 group"
                  >
                    <div class="flex items-start justify-between gap-3 mb-3">
                      <h3 class="text-base font-semibold text-gray-900 dark:text-gray-50 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                        {pb.data.title}
                      </h3>
                      <span class={`shrink-0 inline-flex items-center rounded-md px-2 py-0.5 text-[10px] font-medium ring-1 ring-inset ${audienceColors[pb.data.audience] || ""}`}>
                        {pb.data.audience}
                      </span>
                    </div>

                    <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2 mb-4">
                      {pb.data.description}
                    </p>

                    <div class="flex flex-wrap gap-1.5">
                      <span class="inline-flex items-center rounded-md px-2 py-0.5 text-[10px] font-medium bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400">
                        {pb.data.category}
                      </span>
                      <span class="inline-flex items-center rounded-md px-2 py-0.5 text-[10px] font-medium text-gray-400 dark:text-gray-500">
                        {pb.data.time_estimate}
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </AppShell>
</BaseLayout>
