---
import AppLogo from "./Logo.astro";
import { Icon } from "astro-icon/components";
import config from "@util/themeConfig";

const socials = Object.values(config.footer.socials);
const socialNames = Object.keys(config.footer.socials);
---

<footer
  class="border-t border-gray-100 dark:border-gray-800"
  aria-labelledby="footer-heading"
>
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-7xl px-6 py-12 md:flex md:items-center md:justify-between lg:px-8">
    <div class="flex justify-center space-x-6 md:order-2">
      {
        socials.map((item, index) => (
          <a href={item?.link} target="_blank" rel="noopener" class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300">
            <span class="sr-only">{socialNames[index]}</span>
            <Icon
              name={
                config.ui.icons[
                  socialNames[index] as keyof typeof config.ui.icons
                ]
              }
              class="h-5 w-5"
              aria-hidden="true"
            />
          </a>
        ))
      }
    </div>
    <div class="mt-8 md:order-1 md:mt-0">
      <p class="text-center text-sm text-gray-400">
        &copy; {new Date().getFullYear()} crmarcade. Built by <a href="https://salesforcebinge.com" target="_blank" rel="noopener" class="hover:text-gray-600 dark:hover:text-gray-300">Salesforce Binge</a>.
      </p>
    </div>
  </div>
</footer>
