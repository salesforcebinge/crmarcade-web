---
import "@fontsource-variable/inter";
import themeConfig from "@util/themeConfig";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { getOGImage } from "@util/getOGImage";

const { title, slug, description } = Astro.props;
const siteTitle = themeConfig.general.title;
const siteDescription = themeConfig.general.seo.description;
const siteUrl = themeConfig.general.seo.url;

const calculatedTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const calculatedDescription = description || siteDescription;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteTitle,
  "description": siteDescription,
  "url": siteUrl,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={calculatedDescription} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <title>{calculatedTitle}</title>

    <!-- Facebook Meta Tags -->
    <meta property="og:url" content={siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={calculatedTitle} />
    <meta property="og:description" content={calculatedDescription} />
    <meta property="og:image" content={getOGImage(slug)} />

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="crmarcade.com" />
    <meta property="twitter:url" content={siteUrl} />
    <meta name="twitter:title" content={calculatedTitle} />
    <meta name="twitter:description" content={calculatedDescription} />
    <meta name="twitter:image" content={getOGImage(slug)} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <ClientRouter />
  </head>
  <body class="bg-white dark:bg-gray-900">
    <slot />
  </body>
</html>
