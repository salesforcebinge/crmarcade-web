---
import BaseLayout from "./BaseLayout.astro";
import AppProse from "../components/app/Prose.astro";
import AppShell from "@components/app/AppShell.astro";
import { Icon } from "astro-icon/components";

const { frontmatter, slug } = Astro.props;

const title = frontmatter?.title;
const description = frontmatter?.description;
const question = frontmatter?.question;
const industry = frontmatter?.industry;
const difficulty = frontmatter?.difficulty;
const domains = frontmatter?.domains || [];
const clouds = frontmatter?.clouds || [];
const solution_components = frontmatter?.solution_components || [];
const tools_referenced = frontmatter?.tools_referenced || [];
const quick_refs_referenced = frontmatter?.quick_refs_referenced || [];
const sf_references = frontmatter?.sf_references || [];
const well_architected = frontmatter?.well_architected || [];

const difficultyColors: Record<string, string> = {
  "Foundational": "bg-green-50 text-green-700 ring-green-600/20 dark:bg-green-400/10 dark:text-green-400 dark:ring-green-400/30",
  "Intermediate": "bg-amber-50 text-amber-700 ring-amber-600/20 dark:bg-amber-400/10 dark:text-amber-400 dark:ring-amber-400/30",
  "CTA-Level": "bg-red-50 text-red-700 ring-red-600/20 dark:bg-red-400/10 dark:text-red-400 dark:ring-red-400/30",
};
---

<BaseLayout title={title} description={description} slug={`scenarios/${slug}`}>
  <AppShell>
    <div class="max-w-3xl w-full mx-auto py-16 px-6">
      {/* Back link */}
      <a href="/scenarios" class="inline-flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 mb-8 transition-colors">
        <Icon name="tabler:arrow-left" class="w-4 h-4" />
        All Scenarios
      </a>

      {/* Question callout */}
      {question && (
        <div class="mb-6 rounded-lg border border-primary-200 dark:border-primary-800 bg-primary-50 dark:bg-primary-950/50 p-4">
          <p class="text-sm font-medium text-primary-700 dark:text-primary-300 italic">
            "{question}"
          </p>
        </div>
      )}

      {/* Title */}
      <h1 class="font-bold text-3xl sm:text-4xl text-gray-900 dark:text-gray-50 mb-3">
        {title}
      </h1>
      <p class="text-gray-500 dark:text-gray-400 text-lg mb-8">{description}</p>

      {/* Metadata Bar */}
      <div class="mb-10 rounded-lg border border-gray-200 dark:border-gray-700 p-5 bg-gray-50 dark:bg-gray-800/50">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
          {industry && (
            <div>
              <span class="text-gray-500 dark:text-gray-400 text-xs uppercase tracking-wider">Industry</span>
              <p class="font-medium text-gray-900 dark:text-gray-100 mt-0.5">{industry}</p>
            </div>
          )}
          {difficulty && (
            <div>
              <span class="text-gray-500 dark:text-gray-400 text-xs uppercase tracking-wider">Complexity</span>
              <p class="mt-0.5">
                <span class={`inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium ring-1 ring-inset ${difficultyColors[difficulty] || ""}`}>
                  {difficulty}
                </span>
              </p>
            </div>
          )}
        </div>

        {/* Domains */}
        {domains.length > 0 && (
          <div class="mt-4">
            <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400">Architecture Domains</span>
            <div class="flex flex-wrap gap-1.5 mt-1.5">
              {domains.map((domain: string) => (
                <span class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-700 ring-1 ring-inset ring-gray-300 dark:bg-gray-700 dark:text-gray-300 dark:ring-gray-600">
                  {domain}
                </span>
              ))}
            </div>
          </div>
        )}

        {/* Clouds */}
        {clouds.length > 0 && (
          <div class="mt-3">
            <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400">Salesforce Clouds</span>
            <div class="flex flex-wrap gap-1.5 mt-1.5">
              {clouds.map((cloud: string) => (
                <span class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium bg-primary-50 text-primary-700 ring-1 ring-inset ring-primary-600/20 dark:bg-primary-400/10 dark:text-primary-400 dark:ring-primary-400/30">
                  {cloud}
                </span>
              ))}
            </div>
          </div>
        )}

        {/* Well-Architected Pillars */}
        {well_architected.length > 0 && (
          <div class="mt-3">
            <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400">Well-Architected</span>
            <div class="flex flex-wrap gap-1.5 mt-1.5">
              {well_architected.map((pillar: string) => (
                <span class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium bg-violet-50 text-violet-700 ring-1 ring-inset ring-violet-600/20 dark:bg-violet-400/10 dark:text-violet-400 dark:ring-violet-400/30">
                  {pillar}
                </span>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* Main Content */}
      <AppProse>
        <slot />
      </AppProse>

      {/* Referenced Items Footer */}
      {(tools_referenced.length > 0 || solution_components.length > 0 || quick_refs_referenced.length > 0 || sf_references.length > 0) && (
        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-4">
            Referenced in This Scenario
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm">
            {tools_referenced.length > 0 && (
              <div>
                <span class="text-xs uppercase tracking-wider text-gray-400 dark:text-gray-500">Tools</span>
                <ul class="mt-2 space-y-1">
                  {tools_referenced.map((tool: string) => (
                    <li>
                      <a href={`/${tool}`} class="text-primary-600 dark:text-primary-400 hover:underline">
                        {tool}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {solution_components.length > 0 && (
              <div>
                <span class="text-xs uppercase tracking-wider text-gray-400 dark:text-gray-500">Solution Components</span>
                <ul class="mt-2 space-y-1">
                  {solution_components.map((comp: string) => (
                    <li class="text-gray-700 dark:text-gray-300">{comp}</li>
                  ))}
                </ul>
              </div>
            )}
            {quick_refs_referenced.length > 0 && (
              <div>
                <span class="text-xs uppercase tracking-wider text-gray-400 dark:text-gray-500">Quick References</span>
                <ul class="mt-2 space-y-1">
                  {quick_refs_referenced.map((ref: string) => (
                    <li>
                      <a href={`/quick-refs/${ref}`} class="text-primary-600 dark:text-primary-400 hover:underline">
                        {ref}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {sf_references.length > 0 && (
              <div>
                <span class="text-xs uppercase tracking-wider text-gray-400 dark:text-gray-500">Salesforce Architecture</span>
                <ul class="mt-2 space-y-1">
                  {sf_references.map((ref: { title: string; url: string; type: string }) => (
                    <li>
                      <a href={ref.url} target="_blank" rel="noopener" class="text-primary-600 dark:text-primary-400 hover:underline inline-flex items-center gap-1">
                        {ref.title}
                        <Icon name="tabler:arrow-up-right" class="w-3 h-3" />
                      </a>
                      <span class="text-xs text-gray-400 ml-1">({ref.type})</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  </AppShell>
</BaseLayout>
